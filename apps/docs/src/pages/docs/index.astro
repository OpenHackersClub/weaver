---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { nav } from "../../lib/nav";
---

<BaseLayout title="Docs — weaver" description="Documentation for weaver — the editor for AI co-authorship.">
  <div class="docs-index">
    <header class="docs-index__header">
      <div>
        <span class="section-marker">§ / Documentation</span>
        <h1>weaver, documented.</h1>
      </div>
      <p>
        Start with the introduction, then explore how weaver works — its architecture, the
        hard implementation problems, access control, and AI agent design — plus reference
        material and the decisions on record.
      </p>
    </header>

    {
      nav.map((section) => (
        <section class="docs-index__section">
          <header class="docs-index__section-header">
            <span class="docs-index__section-num">§{section.number}</span>
            <h2 class="docs-index__section-title">{section.title}</h2>
          </header>
          <div class="docs-index__grid">
            {section.items.map((item) => (
              <a class="docs-index__card" href={`/docs/${item.slug}`}>
                <span class="docs-index__card-title">{item.label}</span>
                {item.blurb && <p class="docs-index__card-blurb">{item.blurb}</p>}
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>
