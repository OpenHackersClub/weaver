---
import { getCollection, render } from "astro:content";
import DocLayout from "../../layouts/DocLayout.astro";
import { allItems } from "../../lib/nav";

export async function getStaticPaths() {
  const docs = await getCollection("specs");
  return docs.map((doc) => ({
    params: { slug: doc.id.replace(/\.md$/, "") },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content, headings } = await render(doc);

// Derive a title: prefer frontmatter, then the first H1 from the body,
// then a humanized version of the slug.
function humanize(s: string): string {
  return s
    .replace(/^\d+-/, "")
    .replace(/[-_/]/g, " ")
    .replace(/\b\w/g, (m) => m.toUpperCase());
}

const navItem = allItems().find((i) => i.slug === doc.id.replace(/\.md$/, ""));
const fmTitle = (doc.data as { title?: string } | undefined)?.title;
const firstH1 = headings.find((h) => h.depth === 1)?.text;
const title = fmTitle ?? navItem?.label ?? firstH1 ?? humanize(doc.id);
const description = (doc.data as { description?: string } | undefined)?.description;

// Remove the first H1 from rendered headings (used in DocHeader) so the
// outline doesn't repeat the page title.
const outlineHeadings = headings.filter((h) => h.depth >= 2);
---

<DocLayout
  title={title}
  description={description}
  slug={doc.id.replace(/\.md$/, "")}
  headings={outlineHeadings}
>
  <Content />
</DocLayout>
