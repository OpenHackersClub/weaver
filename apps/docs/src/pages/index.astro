---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroDiagram from "../components/HeroDiagram.astro";
import { site } from "../lib/site";

const tenets = [
  { id: "D1", title: "LoroDoc is the single source of truth", body: "No parallel editor state. History runs through Loro's peer-scoped UndoManager. Time travel and forks are first-class." },
  { id: "D6", title: "Loro as the CRDT core", body: "Rust-native, WASM build, native rich-text marks, peer-scoped undo. Same engine in browser and Durable Object." },
  { id: "D9", title: "AI agents are CRDT peers", body: "Token streams become Loro inserts. Presence, cursors, undo origin, scoped grants — same primitives as humans." },
  { id: "D7", title: "Subdoc partitioning for tiers", body: "Confidentiality tiers as separate LoroDocs. Restricted updates never reach the wire of unauthorized clients. Org-level data scoping done right." },
  { id: "D11", title: "Cloudflare DO per document", body: "Stateful WebSocket hub with hibernation. R2 for snapshots. D1 for ACL. KV for revocations." },
  { id: "D19", title: "Trust the server you run", body: "Cooperative-org trust model. Access control is data scoping, not zero-trust insider defense. Audit-grade attribution carries the compliance load." },
];
---

<BaseLayout title="weaver — the editor for AI co-authorship" description={site.blurb}>
  <section class="hero">
    <div class="container">
      <div class="hero__meta">
        <span class="section-marker reveal" data-delay="1">§00 / Manifest</span>
        <span class="section-marker reveal" data-delay="1">{site.status}</span>
      </div>
      <h1 class="hero__title reveal" data-delay="2">
        The editor for products where AI agents are <em>co&#8209;authors</em>,
        not assistants.
      </h1>
      <p class="hero__sub reveal" data-delay="3">
        weaver is a TypeScript Notion-style block editor with first-class CRDT collaboration —
        for humans, and for agents. Loro under the hood. Local-first, OPFS-persisted, edge-native
        on Cloudflare. Server-enforced access control with cryptographic attribution on every op.
      </p>
      <div class="hero__cta reveal" data-delay="4">
        <a class="btn" href="/docs">Read the docs</a>
        <a class="btn btn--ghost" href="/docs/comparison">vs. other editors</a>
      </div>
    </div>
    <HeroDiagram />
  </section>

  <section class="manifesto">
    <div class="container">
      <div class="manifesto__header">
        <span class="section-marker">§01 / Tenets in prose</span>
        <h2>What we mean by "first-class."</h2>
      </div>
      <ol class="manifesto__list">
        <li class="manifesto__item">
          <span class="manifesto__num">§01.01</span>
          <div>
            <p class="manifesto__statement">An agent is <strong>a peer</strong>, not an API client.</p>
            <p class="manifesto__body">It holds its own capability token. It opens its own WebSocket. Its edits land as Loro ops with <code>origin: agent-N</code>. Cursor, presence, undo scope — same primitives as a human.</p>
          </div>
        </li>
        <li class="manifesto__item">
          <span class="manifesto__num">§01.02</span>
          <div>
            <p class="manifesto__statement">The CRDT <strong>is</strong> the document.</p>
            <p class="manifesto__body">No parallel editor state. No bridge to keep in sync. History runs through Loro's peer-scoped UndoManager. Forks, snapshots, time travel — built in.</p>
          </div>
        </li>
        <li class="manifesto__item">
          <span class="manifesto__num">§01.03</span>
          <div>
            <p class="manifesto__statement">Every edit is <strong>cryptographically attributable</strong>.</p>
            <p class="manifesto__body">Origin is server-rewritten to the authenticated subject. The audit log is hash-chained on R2. A regulator asks "who did this," there's a one-line answer.</p>
          </div>
        </li>
        <li class="manifesto__item">
          <span class="manifesto__num">§01.04</span>
          <div>
            <p class="manifesto__statement">Trust your <strong>own server</strong>. Scope your users' data.</p>
            <p class="manifesto__body">weaver is for orgs that run their own sync — cooperative users on a trusted backend, not zero-trust insider defense. Access control is per-tier data scoping at the sync surface. Audit-grade attribution carries the compliance load.</p>
          </div>
        </li>
        <li class="manifesto__item">
          <span class="manifesto__num">§01.05</span>
          <div>
            <p class="manifesto__statement">Confidentiality is a <strong>sync surface</strong>, not a CSS class.</p>
            <p class="manifesto__body">Tiered content lives in separate LoroDocs. Restricted streams literally never reach unauthorized peers. No op-level redaction; no fragile filter that one bug can break.</p>
          </div>
        </li>
        <li class="manifesto__item">
          <span class="manifesto__num">§01.06</span>
          <div>
            <p class="manifesto__statement">The core has <strong>no React</strong>, <strong>no DOM</strong>.</p>
            <p class="manifesto__body">Headless by construction. React renders chrome. The editing surface is imperative DOM patched from Loro diff events. The pattern every serious editor arrives at the hard way.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <section class="tenets">
    <div class="container">
      <div class="tenets__header">
        <span class="section-marker">§02 / Decisions on file</span>
        <h2>Eighteen decisions. Four ADRs. Read them.</h2>
      </div>
      <div class="tenets__grid">
        {tenets.map((t) => (
          <article class="tenet">
            <span class="tenet__id">{t.id}</span>
            <h3 class="tenet__title">{t.title}</h3>
            <p class="tenet__rationale">{t.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container">
    <div class="cta-band">
      <div>
        <span class="section-marker">§04 / Read on</span>
        <h2>Everything weaver, documented.</h2>
      </div>
      <div class="cta-band__actions">
        <a class="btn" href="/docs">Browse the docs</a>
        <a class="btn btn--ghost" href={site.repo} target="_blank" rel="noreferrer noopener">View on GitHub ↗</a>
      </div>
    </div>
  </section>
</BaseLayout>
