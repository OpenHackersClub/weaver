---
import { site } from "../lib/site";

const now = new Date();
const stamp = now.toISOString().slice(0, 10);
---

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">
      <div class="site-footer__col">
        <h4>Specifications</h4>
        <ul>
          <li><a href="/docs/prd">Product Requirements</a></li>
          <li><a href="/docs/architecture">System Architecture</a></li>
          <li><a href="/docs/access-control">Access Control</a></li>
          <li><a href="/docs/ai-agent">AI Agent</a></li>
          <li><a href="/docs/comparison">Editor Comparison</a></li>
        </ul>
      </div>
      <div class="site-footer__col">
        <h4>Decisions</h4>
        <ul>
          <li><a href="/docs/adr/0001-adopt-loro-over-yjs">ADR 0001 — Loro</a></li>
          <li><a href="/docs/adr/0002-notion-style-block-model">ADR 0002 — Blocks</a></li>
          <li><a href="/docs/adr/0003-concurrent-semantics-no-global-rw-aw">ADR 0003 — Concurrent semantics</a></li>
          <li><a href="/docs/adr/0004-capability-token-format">ADR 0004 — Tokens</a></li>
        </ul>
      </div>
    </div>
    <div class="site-footer__stamp">
      <span>status / {site.status}</span>
      <span>build / {stamp}</span>
      <span>repo / <a href={site.repo} target="_blank" rel="noreferrer noopener">{site.repo.replace("https://", "")}</a></span>
    </div>
  </div>
</footer>
