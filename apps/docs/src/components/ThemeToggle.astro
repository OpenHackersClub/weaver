---

<button class="theme-toggle" id="theme-toggle" aria-label="Toggle color theme" type="button">
  <svg class="theme-toggle__moon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M13 9.5A5.5 5.5 0 0 1 6.5 3a5.5 5.5 0 1 0 6.5 6.5z"/>
  </svg>
  <svg class="theme-toggle__sun" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="8" cy="8" r="2.6"/>
    <path d="M8 1v2M8 13v2M1 8h2M13 8h2M2.7 2.7l1.4 1.4M11.9 11.9l1.4 1.4M2.7 13.3l1.4-1.4M11.9 4.1l1.4-1.4"/>
  </svg>
</button>

<script is:inline>
  (function () {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;
    btn.addEventListener("click", function () {
      var current = document.documentElement.getAttribute("data-theme") || "light";
      var next = current === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      try { localStorage.setItem("weaver:theme", next); } catch (_) {}
      // Notify mermaid runner to re-render with the new theme
      window.dispatchEvent(new CustomEvent("weaver:theme-change", { detail: { theme: next } }));
    });
  })();
</script>
