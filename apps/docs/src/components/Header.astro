---
import ThemeToggle from "./ThemeToggle.astro";

const path = Astro.url.pathname;
const isDocs = path.startsWith("/docs");
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__brand" aria-label="weaver home">
      <span class="site-header__brand-mark" aria-hidden="true"></span>
      weaver<em>v0.0.0-pre</em>
    </a>
    <nav class="site-header__nav" aria-label="Primary">
      <a href="/" aria-current={path === "/" ? "page" : undefined}>Index</a>
      <a href="/docs" aria-current={isDocs ? "page" : undefined}>Docs</a>
      <a href="https://github.com/OpenHackersClub/weaver" target="_blank" rel="noreferrer noopener">Repo ↗</a>
      <ThemeToggle />
    </nav>
  </div>
</header>
